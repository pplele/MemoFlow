# MemoFlow 环境配置

# ========== AI 模型配置 ==========

# 通用 LLM 配置 (推荐使用)
LLM_PROVIDER=doubao
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-1-5-pro-32k
LLM_EMBEDDING_MODEL=doubao-embedding
LLM_TEMPERATURE=0.3

# 豆包 API (兼容旧配置)
DOUBAO_API_KEY=your_api_key_here
DOUBAO_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-1-5-pro-32k
DOUBAO_EMBEDDING_MODEL=doubao-embedding

# Ollama 本地模型配置 (可选)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# ========== 服务器配置 ==========

PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ========== Obsidian Vault ==========

VAULT_PATH=./vault
VAULT_WATCH_ENABLED=true
VAULT_WATCH_DEBOUNCE_MS=500

# ========== 数据库 ==========

DB_PATH=./server/data/memoflow.db

# ========== 飞书机器人 (可选) ==========

FEISHU_WEBHOOK_URL=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_NOTIFY_CHAT_ID=

# ========== 文件上传 ==========

MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,docx,xlsx,pptx,jpg,jpeg,png,gif,txt,zip,rar,7z

