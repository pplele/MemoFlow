# MemoFlow 环境配置

# 豆包 API (火山引擎方舟)
DOUBAO_API_KEY=your_api_key_here
DOUBAO_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-1-5-pro-32k
DOUBAO_EMBEDDING_MODEL=doubao-embedding

# 服务器配置
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Obsidian Vault 路径 (相对路径或绝对路径)
VAULT_PATH=./vault
VAULT_WATCH_ENABLED=true
VAULT_WATCH_DEBOUNCE_MS=500

# 数据库
DB_PATH=./server/data/memoflow.db

# 飞书机器人 (可选)
FEISHU_WEBHOOK_URL=
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 文件上传
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,docx,xlsx,pptx,jpg,jpeg,png,gif
